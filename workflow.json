    {
      "parameters": {
        "jsCode": "// Extract topic and chat_id from previous nodes\nconst topic = $('Extract Topic').first().json.topic;\nconst chat_id = $('Extract Topic').first().json.chat_id;\n\n// Get search results\nconst searchData = $input.first().json;\n\n// Extract snippets from organic results\nlet snippets = '';\nif (searchData.organic && searchData.organic.length > 0) {\n  snippets = searchData.organic\n    .slice(0, 5)\n    .map((r, i) => `${i + 1}. ${r.title}: ${r.snippet || ''}`)\n    .join('\\n');\n} else {\n  snippets = 'No search results found. Use general knowledge about this topic.';\n}\n\nreturn [{\n  json: {\n    topic: topic,\n    chat_id: chat_id,\n    research: snippets\n  }\n}];"
      },
      "id": "2d3509d4-e273-4592-89dd-b85c84239d6c",
      "name": "Prepare Research",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        672,
        0
      ]
    },
    {
      "parameters": {
        "jsCode": "const chat_id = $('Prepare Research').first().json.chat_id;\nconst topic = $('Prepare Research').first().json.topic;\n\n// LLM Chain returns { text: \"...\" }\nlet content = $input.first().json.text;\n\n// Clean up markdown if present\ncontent = content.replace(/```json/gi, '').replace(/```/g, '').trim();\n\n// Parse JSON\nlet scripts;\ntry {\n  scripts = JSON.parse(content);\n} catch (e) {\n  return [{\n    json: {\n      chat_id: chat_id,\n      text: `⚠️ Could not parse scripts for \"${topic}\". Raw response:\\n\\n${content}`\n    }\n  }];\n}\n\n// Format each script as telegram message\nreturn scripts.map((s) => ({\n  json: {\n    chat_id: chat_id,\n    text: `📝 *Script ${s.script_number}/3*\\n🎯 *Angle:* ${s.angle}\\n🪝 *Hook:* _${s.hook}_\\n\\n${s.script}\\n\\n━━━━━━━━━━━━━━━\\n✅ Ready to record!`\n  }\n}));"
      },
